<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Compresor de Video — 100% en el navegador</title>
<style>
  :root{
    --bg:#0b0d10;
    --panel:#14171b;
    --line:#242830;
    --text:#e7e9ec;
    --dim:#8a909a;
    --accent:#5ee0c0;
    --warn:#e0a75e;
    --mono: "IBM Plex Mono","SFMono-Regular",Consolas,monospace;
    --sans: "Inter","Helvetica Neue",Arial,sans-serif;
  }
  *{box-sizing:border-box;}
  html,body{ margin:0; min-height:100%; background:var(--bg); color:var(--text); font-family:var(--sans); }
  #app{ max-width:920px; margin:0 auto; padding:40px 24px 80px; }

  .eyebrow{ font-family:var(--mono); font-size:10px; letter-spacing:.14em; color:var(--accent); text-transform:uppercase; }
  h1{ font-size:22px; margin:8px 0 6px; font-weight:600; }
  .lede{ color:var(--dim); font-size:13px; line-height:1.6; max-width:640px; margin:0 0 32px; }
  .lede b{ color:var(--text); }

  .card{ background:var(--panel); border:1px solid var(--line); border-radius:3px; padding:20px 22px; margin-bottom:16px; }
  .card h2{ font-family:var(--mono); font-size:10px; letter-spacing:.12em; text-transform:uppercase; color:var(--dim); margin:0 0 14px; }

  #engineRow{ display:flex; align-items:center; gap:14px; flex-wrap:wrap; }
  #engineStatus{ font-family:var(--mono); font-size:11.5px; color:var(--dim); flex:1; min-width:180px; }
  #engineStatus b{ color:var(--accent); }
  .barOuter{ width:100%; height:3px; background:var(--line); border-radius:2px; overflow:hidden; margin-top:10px; }
  .barInner{ height:100%; width:0%; background:var(--accent); transition:width .15s linear; }

  #dropzone{
    border:1px dashed var(--line); border-radius:2px; padding:26px; text-align:center;
    font-family:var(--mono); font-size:12px; color:var(--dim); cursor:pointer; transition:border-color .15s, color .15s;
  }
  #dropzone:hover, #dropzone.drag{ border-color:var(--accent); color:var(--accent); }
  #fileInput{ display:none; }

  video{ width:100%; border-radius:2px; margin-top:14px; display:none; background:#000; }

  .row{ display:flex; align-items:center; gap:12px; margin-bottom:14px; }
  .row:last-child{ margin-bottom:0; }
  .row label{ font-family:var(--mono); font-size:11px; color:var(--dim); width:130px; flex-shrink:0; }
  .row select, .row input[type=range]{ flex:1; }
  select{
    background:var(--bg); color:var(--text); border:1px solid var(--line); border-radius:2px;
    font-family:var(--mono); font-size:11.5px; padding:7px 8px;
  }
  input[type=range]{ -webkit-appearance:none; height:2px; background:var(--line); outline:none; border-radius:2px; }
  input[type=range]::-webkit-slider-thumb{
    -webkit-appearance:none; width:11px; height:11px; border-radius:50%;
    background:var(--accent); cursor:pointer; box-shadow:0 0 0 3px rgba(94,224,192,.15);
  }
  .row .val{ font-family:var(--mono); font-size:11px; color:var(--accent); width:64px; text-align:right; flex-shrink:0; }

  button{
    font-family:var(--mono); font-size:11.5px; letter-spacing:.03em; text-transform:uppercase;
    background:transparent; color:var(--text); border:1px solid var(--line); border-radius:2px;
    padding:10px 16px; cursor:pointer; transition:border-color .15s, color .15s;
  }
  button:hover:not(:disabled){ border-color:var(--accent); color:var(--accent); }
  button.primary{ background:var(--accent); color:#04120e; border-color:var(--accent); font-weight:600; }
  button.primary:hover:not(:disabled){ opacity:.9; color:#04120e; }
  button:disabled{ opacity:.3; cursor:not-allowed; }

  #log{
    font-family:var(--mono); font-size:10.5px; color:var(--dim); background:var(--bg);
    border:1px solid var(--line); border-radius:2px; padding:10px 12px; height:110px; overflow-y:auto;
    white-space:pre-wrap; margin-top:14px; display:none;
  }

  #results{ display:none; }
  .statPair{ display:flex; gap:24px; font-family:var(--mono); font-size:12px; margin-bottom:14px; }
  .stat b{ display:block; font-size:18px; color:var(--accent); }
  .stat span{ color:var(--dim); font-size:10px; text-transform:uppercase; letter-spacing:.08em; }

  .note{
    font-family:var(--mono); font-size:10.5px; color:var(--warn); border:1px solid #4a3a24; background:#1c1710;
    border-radius:2px; padding:10px 12px; line-height:1.6; margin-top:16px;
  }
</style>
</head>
<body>
<div id="app">
  <div class="eyebrow">WebAssembly · ffmpeg.wasm</div>
  <h1>Compresor de video en el navegador</h1>
  <p class="lede">Corre <b>ffmpeg real compilado a WebAssembly</b>, 100% local: el archivo nunca se sube a ningún servidor. Bajás resolución/bitrate y descargás el resultado ahí mismo.</p>

  <div class="card">
    <h2>01 · Motor</h2>
    <div id="engineRow">
      <div id="engineStatus">Motor no cargado (~25&nbsp;MB, se descarga una sola vez).</div>
      <button class="primary" id="loadBtn">Cargar motor</button>
    </div>
    <div class="barOuter"><div class="barInner" id="loadBar"></div></div>
  </div>

  <div class="card">
    <h2>02 · Video</h2>
    <div id="dropzone">Click o arrastrá un archivo de video acá</div>
    <input type="file" id="fileInput" accept="video/*">
    <video id="preview" controls></video>
  </div>

  <div class="card">
    <h2>03 · Ajustes de compresión</h2>
    <div class="row">
      <label>Resolución</label>
      <select id="scale">
        <option value="1">Original</option>
        <option value="0.75">75%</option>
        <option value="0.5" selected>50%</option>
        <option value="0.33">33%</option>
      </select>
    </div>
    <div class="row">
      <label>Calidad (CRF)</label>
      <input type="range" id="crf" min="18" max="35" step="1" value="28">
      <span class="val" id="v_crf">28 (media)</span>
    </div>
    <div class="row">
      <label>Velocidad encode</label>
      <select id="preset">
        <option value="ultrafast">Ultrafast (archivo más pesado)</option>
        <option value="veryfast" selected>Veryfast (recomendado)</option>
        <option value="medium">Medium (más lento, más chico)</option>
      </select>
    </div>
    <div class="row">
      <label>Audio</label>
      <select id="audio">
        <option value="128k" selected>AAC 128kbps</option>
        <option value="64k">AAC 64kbps</option>
        <option value="none">Sin audio</option>
      </select>
    </div>
    <div style="margin-top:18px;">
      <button class="primary" id="compressBtn" disabled>Comprimir</button>
    </div>
    <div id="log"></div>
  </div>

  <div class="card" id="results">
    <h2>04 · Resultado</h2>
    <div class="statPair">
      <div class="stat"><b id="sizeOriginal">—</b><span>Original</span></div>
      <div class="stat"><b id="sizeCompressed">—</b><span>Comprimido</span></div>
      <div class="stat"><b id="sizeReduction">—</b><span>Reducción</span></div>
    </div>
    <a id="downloadLink" download="comprimido.mp4"><button class="primary">Descargar video comprimido</button></a>
  </div>

  <div class="note">
    Si el motor no carga: algunos navegadores bloquean la carga de WebAssembly cuando el HTML se abre directo como archivo (<code>file://</code>). Si eso pasa, serví esta carpeta con un server local, por ejemplo <code>python3 -m http.server</code>, y abrí <code>http://localhost:8000/video_compressor.html</code>.
  </div>
</div>

<script>
// ---------- Carga robusta de la librería (con CDN de respaldo) ----------
const FFMPEG_JS_URLS = [
  'https://unpkg.com/@ffmpeg/ffmpeg@0.11.6/dist/ffmpeg.min.js',
  'https://cdn.jsdelivr.net/npm/@ffmpeg/ffmpeg@0.11.6/dist/ffmpeg.min.js',
];
const FFMPEG_CORE_URLS = [
  'https://unpkg.com/@ffmpeg/core@0.11.0/dist/ffmpeg-core.js',
  'https://cdn.jsdelivr.net/npm/@ffmpeg/core@0.11.0/dist/ffmpeg-core.js',
];

function loadScriptTag(url){
  return new Promise((resolve, reject) => {
    const s = document.createElement('script');
    s.src = url;
    s.onload = () => resolve(url);
    s.onerror = () => reject(new Error('No se pudo cargar ' + url));
    document.head.appendChild(s);
  });
}

async function loadLibraryWithFallback(urls){
  let lastErr;
  for(const url of urls){
    try{
      await loadScriptTag(url);
      if(typeof window.FFmpeg !== 'undefined') return url;
      lastErr = new Error('Script cargó pero no definió window.FFmpeg: ' + url);
    }catch(err){
      lastErr = err;
    }
  }
  throw lastErr;
}

const engineStatusEarly = document.getElementById('engineStatus');
const loadBtnEarly = document.getElementById('loadBtn');
loadBtnEarly.disabled = true;
engineStatusEarly.textContent = 'Cargando librería ffmpeg.wasm…';

let libraryReady = false;
let workingCorePath = FFMPEG_CORE_URLS[0];

loadLibraryWithFallback(FFMPEG_JS_URLS).then((usedUrl) => {
  libraryReady = true;
  // usar el core del mismo proveedor que sí funcionó, si es posible
  workingCorePath = usedUrl.includes('jsdelivr') ? FFMPEG_CORE_URLS[1] : FFMPEG_CORE_URLS[0];
  engineStatusEarly.innerHTML = 'Librería lista. Click en <b>"Cargar motor"</b> para descargar el core (~25MB).';
  loadBtnEarly.disabled = false;
}).catch((err) => {
  engineStatusEarly.innerHTML = '<b style="color:var(--warn)">No se pudo cargar ffmpeg.wasm.</b> Revisá tu conexión, un adblocker, o si estás abriendo el archivo como file:// (mirá la nota de más abajo).';
  console.error(err);
});

const loadBtn = document.getElementById('loadBtn');
const engineStatus = document.getElementById('engineStatus');
const loadBar = document.getElementById('loadBar');
const dropzone = document.getElementById('dropzone');
const fileInput = document.getElementById('fileInput');
const preview = document.getElementById('preview');
const compressBtn = document.getElementById('compressBtn');
const logEl = document.getElementById('log');
const results = document.getElementById('results');

let currentFile = null;
let engineReady = false;

function log(msg){
  logEl.style.display = 'block';
  logEl.textContent += msg + '\n';
  logEl.scrollTop = logEl.scrollHeight;
}

let ffmpeg = null;

loadBtn.addEventListener('click', async () => {
  if(!libraryReady){
    engineStatus.textContent = 'La librería todavía no cargó, esperá un momento y reintentá.';
    return;
  }
  loadBtn.disabled = true;
  logEl.style.display = 'block';
  logEl.textContent = '';
  engineStatus.textContent = 'Descargando motor ffmpeg (~25MB, puede tardar según tu conexión)…';
  loadBar.style.width = '15%'; // indeterminado: solo indica "en curso"

  const { createFFmpeg } = window.FFmpeg;
  ffmpeg = createFFmpeg({ log: false, corePath: workingCorePath });
  ffmpeg.setLogger(({ message }) => log(message)); // feedback real durante la descarga

  // Aviso si tarda demasiado (posible bloqueo silencioso del entorno de preview)
  const stallWarning = setTimeout(() => {
    engineStatus.innerHTML = 'Está tardando más de lo normal. Si estás viendo esto <b>dentro del preview de Claude</b>, ' +
      'descargá el archivo (botón Copy → guardalo como .html) y abrilo en una pestaña normal del navegador, ' +
      'o corré un server local (ver nota de abajo). Puede que el iframe de preview esté limitando la descarga.';
  }, 20000);

  try{
    await ffmpeg.load();
    clearTimeout(stallWarning);
    engineReady = true;
    engineStatus.innerHTML = 'Motor listo <b>✓</b>';
    loadBar.style.width = '100%';
    if(currentFile) compressBtn.disabled = false;
  }catch(err){
    clearTimeout(stallWarning);
    engineStatus.textContent = 'Error cargando el motor. Revisá la nota de más abajo (file:// vs servidor local).';
    loadBar.style.width = '0%';
    loadBtn.disabled = false;
    console.error(err);
  }
});

dropzone.addEventListener('click', () => fileInput.click());
dropzone.addEventListener('dragover', e => { e.preventDefault(); dropzone.classList.add('drag'); });
dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag'));
dropzone.addEventListener('drop', e => {
  e.preventDefault();
  dropzone.classList.remove('drag');
  if(e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0]);
});
fileInput.addEventListener('change', e => {
  if(e.target.files.length) handleFile(e.target.files[0]);
});

function handleFile(file){
  currentFile = file;
  preview.src = URL.createObjectURL(file);
  preview.style.display = 'block';
  dropzone.textContent = file.name + ' (' + formatBytes(file.size) + ')';
  results.style.display = 'none';
  if(engineReady) compressBtn.disabled = false;
}

document.getElementById('crf').addEventListener('input', (e) => {
  const v = parseInt(e.target.value);
  let label = v <= 22 ? 'alta' : v <= 29 ? 'media' : 'baja';
  document.getElementById('v_crf').textContent = v + ' (' + label + ')';
});

function formatBytes(bytes){
  if(bytes < 1024*1024) return (bytes/1024).toFixed(0) + ' KB';
  return (bytes/1024/1024).toFixed(2) + ' MB';
}

compressBtn.addEventListener('click', async () => {
  if(!currentFile || !engineReady || !ffmpeg) return;
  compressBtn.disabled = true;
  logEl.textContent = '';
  logEl.style.display = 'block';
  results.style.display = 'none';
  log('Preparando archivo…');

  const inputName = 'input' + (currentFile.name.match(/\.\w+$/)?.[0] || '.mp4');
  const outputName = 'output.mp4';

  const { fetchFile } = window.FFmpeg;
  ffmpeg.FS('writeFile', inputName, await fetchFile(currentFile));

  const scale = document.getElementById('scale').value;
  const crf = document.getElementById('crf').value;
  const preset = document.getElementById('preset').value;
  const audio = document.getElementById('audio').value;

  const args = ['-i', inputName];

  if(scale !== '1'){
    // Escala manteniendo aspect ratio, ancho/alto par (requisito de h264)
    args.push('-vf', `scale=trunc(iw*${scale}/2)*2:trunc(ih*${scale}/2)*2`);
  }

  args.push('-c:v', 'libx264', '-crf', crf, '-preset', preset);

  if(audio === 'none'){
    args.push('-an');
  } else {
    args.push('-c:a', 'aac', '-b:a', audio);
  }

  args.push(outputName);

  ffmpeg.setLogger(({ message }) => log(message));
  ffmpeg.setProgress(({ ratio }) => {
    if(ratio >= 0 && ratio <= 1) log('Progreso: ' + (ratio*100).toFixed(0) + '%');
  });

  log('Comando: ffmpeg ' + args.join(' '));
  log('Comprimiendo… esto puede tardar según el tamaño del video.');

  try{
    await ffmpeg.run(...args);
    const data = ffmpeg.FS('readFile', outputName);
    const blob = new Blob([data.buffer], { type: 'video/mp4' });
    const url = URL.createObjectURL(blob);

    document.getElementById('sizeOriginal').textContent = formatBytes(currentFile.size);
    document.getElementById('sizeCompressed').textContent = formatBytes(blob.size);
    const reduction = (100 - (blob.size / currentFile.size) * 100).toFixed(0);
    document.getElementById('sizeReduction').textContent = reduction + '%';

    const link = document.getElementById('downloadLink');
    link.href = url;
    link.download = currentFile.name.replace(/\.\w+$/, '') + '_comprimido.mp4';

    results.style.display = 'block';
    log('Listo ✓');
  }catch(err){
    log('Error: ' + err.message);
    console.error(err);
  }finally{
    compressBtn.disabled = false;
    // limpiar FS para permitir re-uso
    try{ ffmpeg.FS('unlink', inputName); }catch(e){}
    try{ ffmpeg.FS('unlink', outputName); }catch(e){}
  }
});
</script>
</body>
</html>
